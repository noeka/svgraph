{
    "name": "noeka/svgraph",
    "description": "JavaScript-free SVG chart rendering for PHP. Sparkline, line/area, bar, pie/donut, and progress charts as static markup.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.95",
        "roave/security-advisories": "dev-latest",
        "rector/rector": "^2.0",
        "infection/infection": "^0.29",
        "spatie/phpunit-snapshot-assertions": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Noeka\\Svgraph\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Noeka\\Svgraph\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Mathias N. Kastrup",
            "email": "mathias@noeka.dk"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit",
        "lint": "phpstan analyse",
        "cs": "php-cs-fixer check",
        "cs:fix": "php-cs-fixer fix",
        "rector": "rector --dry-run",
        "rector:fix": "rector",
        "mutate": "infection --threads=max",
        "check": ["@lint", "@cs", "@test"],
        "docs:images": "php examples/run.php"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
